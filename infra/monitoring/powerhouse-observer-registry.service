[Unit]
Description=Power House signed public observer registry reconciliation
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/powerhouse/observer-registry.env
ExecStart=/usr/local/lib/powerhouse/observer_registry.py
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/etc/prometheus/file_sd /var/lib/powerhouse/monitoring
